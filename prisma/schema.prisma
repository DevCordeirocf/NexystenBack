generator client {
  provider = "prisma-client-js"
}

datasource db {
  url      = env("DATABASE_URL")
  provider = "postgresql"
}

enum UserRole {
  MASTER_ADMIN
  TENANT_ADMIN
  CUSTOMER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  role      UserRole @default(CUSTOMER)
  tenantId  String?  // Para TENANT_ADMIN e CUSTOMER, vincula ao TenantStore
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          TenantStore?     @relation(name: "TenantUsers", fields: [tenantId], references: [id])
  contactRequests ContactRequest[] @relation(name: "UserContactRequests")

  @@map("users")
}

model TenantStore {
  id          String   @id @default(uuid())
  name        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  themeConfig Json?    // Configurações de tema em formato JSON

  products        Product[]
  categories      Category[]
  contactRequests ContactRequest[]
  users           User[]           @relation(name: "TenantUsers")

  @@map("tenant_stores")
}

model Category {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   TenantStore @relation(fields: [tenantId], references: [id])
  products Product[]   @relation("ProductCategories")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid())
  tenantId       String
  name           String
  description    String
  price          Decimal  @db.Decimal(10, 2)
  isAvailable    Boolean  @default(true)
  images         String[] // URLs das imagens
  specifications Json?    // JSON flexível para especificações
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant          TenantStore      @relation(fields: [tenantId], references: [id])
  categories      Category[]       @relation("ProductCategories")
  contactRequests ContactRequest[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("products")
}

model ContactRequest {
  id            String   @id @default(uuid())
  tenantId      String
  productId     String
  userId        String?  // Opcional: vincula ao usuário logado (CUSTOMER)
  customerName  String
  customerEmail String
  customerPhone String?
  message       String?
  status        String   @default("PENDING") // PENDING, CONTACTED, CLOSED
  createdAt     DateTime @default(now())

  tenant  TenantStore @relation(fields: [tenantId], references: [id])
  product Product     @relation(fields: [productId], references: [id])
  user    User?       @relation(name: "UserContactRequests", fields: [userId], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@index([userId])
  @@map("contact_requests")
}
